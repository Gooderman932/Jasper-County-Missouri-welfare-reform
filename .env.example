# Copy this file to .env and fill in real values for LOCAL development.
# .env is gitignored — never commit real credentials.
#
# For PRODUCTION builds on EAS, do NOT put values here. Instead run:
#   eas env:create --environment production --name APPWRITE_ENDPOINT --value "https://cloud.appwrite.io/v1"
#   eas env:create --environment production --name APPWRITE_PROJECT_ID --value "your-project-id"
# EAS will inject them into the build worker before app.config.ts evaluates.

# Required for backend features
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id-here

# Optional overrides
APPWRITE_DATABASE_ID=family_rights_main
APPWRITE_ADMIN_TEAM_ID=admin

# Google Play billing product (must match Play Console product configuration)
PREMIUM_PRODUCT_ID=premium_monthly_599
PREMIUM_BASE_PLAN_ID=monthly-autorenew
PREMIUM_OFFER_ID=freetrial-1m

# Sentry crash reporting (optional but strongly recommended for production)
# 1. Sign up free at https://sentry.io
# 2. New Project → React Native
# 3. Project Settings → Client Keys → copy the DSN
# 4. Paste it here for local dev, and add via `eas env:create` for production
# DSN is a public client credential (safe to commit). Override only if you fork to a different Sentry org.
SENTRY_DSN=https://5b6cf054db7121e2ce637a9b07212523@o4511628742033408.ingest.us.sentry.io/4511628770476032
