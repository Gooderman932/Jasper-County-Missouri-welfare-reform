# Family Rights App — environment template
# Copy to .env and fill in real values. Never commit .env.

# Appwrite
APPWRITE_ENDPOINT=https://appwrite.your-domain.com/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=family_rights_main

# Storage buckets
APPWRITE_BUCKET_RAW=raw-documents
APPWRITE_BUCKET_REDACTED=redacted-documents
APPWRITE_BUCKET_AUDIO=audio-notes
APPWRITE_BUCKET_EXPORTS=generated-exports
APPWRITE_BUCKET_TEMP_OCR=temp-ocr

# Google Play
GOOGLE_PLAY_PACKAGE_NAME=com.poordudeholdings.familyrights
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=./service-account.json
PREMIUM_PRODUCT_ID=premium_monthly_599
PREMIUM_BASE_PLAN_ID=monthly-autorenew
PREMIUM_OFFER_ID=freetrial-1m

# OCR (Google Cloud Vision used as default reference implementation)
GOOGLE_CLOUD_VISION_API_KEY=
OCR_PROVIDER=google_vision

# Admin
ADMIN_TEAM_ID=
