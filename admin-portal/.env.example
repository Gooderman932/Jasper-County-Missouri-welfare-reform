# Admin portal (Vite) environment variables.
# Copy to admin-portal/.env.local for local dev. Keys are read via import.meta.env
# so they MUST be prefixed with VITE_ to be exposed to the browser bundle.

VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-appwrite-project-id
VITE_APPWRITE_DATABASE_ID=family_rights_main
