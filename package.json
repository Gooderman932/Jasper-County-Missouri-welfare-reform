{
  "name": "family-rights-app",
  "version": "0.1.0",
  "private": true,
  "description": "Family Rights App — Android-first case intelligence app for parents navigating child-welfare and TPR proceedings. Built around Jasper County, Missouri welfare reform context.",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:local": "EXPO_PUBLIC_USE_MEMORY_REPOS=true expo start --web",
    "summary:draft": "ts-node --transpile-only scripts/generate-case-summary.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest",
    "provision:appwrite": "ts-node scripts/provision-appwrite.ts",
    "provision:appwrite:verify": "ts-node scripts/provision-appwrite.ts --verify-only",
    "provision:appwrite:heal": "ts-node scripts/provision-appwrite.ts --reset-collections=case_events",
    "provision:appwrite:reset-all": "ts-node scripts/provision-appwrite.ts --reset-all",
    "build:android": "eas build --platform android --profile production",
    "submit:android": "eas submit --platform android"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@react-navigation/stack": "^7.10.6",
    "@sentry/react-native": "^8.16.0",
    "date-fns": "^4.4.0",
    "expo": "~56.0.12",
    "expo-application": "~56.0.3",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-image-manipulator": "~56.0.19",
    "expo-image-picker": "~56.0.18",
    "expo-notifications": "~56.0.18",
    "expo-print": "~56.0.4",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.18",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.19",
    "react": "19.2.7",
    "react-dom": "18.2.0",
    "react-native": "0.86.0",
    "react-native-appwrite": "^0.4.0",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-get-random-values": "~1.11.0",
    "react-native-iap": "^12.15.0",
    "react-native-paper": "^5.12.3",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-web": "~0.21.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.17",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^7.1.2",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.3",
    "node-appwrite": "^26.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "~5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
